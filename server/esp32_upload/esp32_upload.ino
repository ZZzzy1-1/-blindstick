#define ALERT_DIST_CHANGE 30          // 距离变化超过30cm才重新播报

// 避障语音去重：记录上次播报的文本和时间
static String last_alert_text = "";
static unsigned long last_alert_text_time = 0;
#define ALERT_TEXT_DUPLICATE_MS 8000  // 相同文本8秒内不重复

